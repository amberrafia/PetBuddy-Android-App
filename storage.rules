rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Animal images - readable by all, writable by authenticated users
    match /animal_images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024  // 5MB limit
                   && request.resource.contentType.matches('image/.*');  // Only images
    }
    
    // Injury photos - readable by all (for veterinary sharing), writable by authenticated users
    match /injury_photos/{allPaths=**} {
      allow read: if true;  // Allow public read for veterinary sharing
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024  // 5MB limit
                   && request.resource.contentType.matches('image/.*');  // Only images
    }
    
    // User profile images - readable by all, writable by owner
    match /user_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024  // 2MB limit
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}