<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Event Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/txtEventTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Event Title"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>

                    <TextView
                        android:id="@+id/txtEventCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎾 Pet Activity"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="#E8F5E8"
                        android:padding="6dp"
                        android:layout_marginStart="12dp"/>

                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:id="@+id/txtEventDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Event description goes here..."
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Date and Time -->
                <TextView
                    android:id="@+id/txtEventDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📅 Date\n⏰ Time"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:background="#F8F9FA"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Location -->
                <TextView
                    android:id="@+id/txtEventLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Location"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:background="#F8F9FA"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Organizer -->
                <TextView
                    android:id="@+id/txtEventOrganizer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👥 Organized by: Organizer Name"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <!-- Participants -->
                <TextView
                    android:id="@+id/txtEventParticipants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👥 Participants: 0/50\n✅ Available slots: 50"
                    android:textSize="14sp"
                    android:textColor="#4CAF50"
                    android:background="#E8F5E8"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Requirements Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/txtEventRequirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Requirements:\nBring your pet on a leash"
                android:textSize="14sp"
                android:textColor="#FF9800"
                android:padding="16dp"/>

        </androidx.cardview.widget.CardView>

        <!-- Contact Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/txtEventContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📞 Contact: contact@example.com"
                android:textSize="14sp"
                android:textColor="#2196F3"
                android:padding="16dp"/>

        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnRegisterEvent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register for Event"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="#4CAF50"
                android:padding="16dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnShareEvent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📤 Share"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2196F3"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnContactOrganizer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📞 Contact"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF9800"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnViewRegistrations"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="👥 Users"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#9C27B0"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>