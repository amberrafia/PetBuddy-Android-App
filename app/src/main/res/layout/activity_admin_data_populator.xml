<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/black">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/primary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👑 Admin Data Populator"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Populate Firebase with real animal data and photos"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:alpha="0.9"
                android:gravity="center"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Status Section -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready to populate database"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:layout_marginBottom="12dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <!-- Populate Dogs Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <Button
                android:id="@+id/btnPopulateDogs"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🐕 Populate Dog Data"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/primary_dark"
                android:textColor="@color/white"
                android:layout_margin="8dp"
                style="@style/Widget.AppCompat.Button.Colored"/>

        </androidx.cardview.widget.CardView>

        <!-- Populate Cats Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <Button
                android:id="@+id/btnPopulateCats"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🐱 Populate Cat Data"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/accent"
                android:textColor="@color/white"
                android:layout_margin="8dp"
                style="@style/Widget.AppCompat.Button.Colored"/>

        </androidx.cardview.widget.CardView>

        <!-- Populate All Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <Button
                android:id="@+id/btnPopulateAll"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🐾 Populate All Animal Data"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/admin_primary"
                android:textColor="@color/white"
                android:layout_margin="8dp"
                style="@style/Widget.AppCompat.Button.Colored"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Information Section -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/primary_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ️ Information"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• This will download real animal photos from the internet\n• Photos will be uploaded to Firebase Storage\n• Animal data will be saved to Firebase Realtime Database\n• Process may take a few minutes to complete\n• Ensure you have a stable internet connection"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:lineSpacingExtra="2dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>