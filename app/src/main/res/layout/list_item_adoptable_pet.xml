<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Pet Photo with Clean Overlay -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/imgPetPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/default_pet_image"/>

            <!-- Subtle Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_alignParentBottom="true"
                android:background="@android:color/black"
                android:alpha="0.2"/>

            <!-- Species Badge -->
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"
                android:layout_margin="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary">

                <TextView
                    android:id="@+id/txtPetSpecies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dog"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

            </androidx.cardview.widget.CardView>

            <!-- Pet Name Overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPetName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bella"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:shadowColor="@color/black"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="2"/>

                <TextView
                    android:id="@+id/txtPetBreed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Golden Retriever"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:alpha="0.9"
                    android:shadowColor="@color/black"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="2"/>

            </LinearLayout>

        </RelativeLayout>

        <!-- Pet Information Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Quick Info Tags -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/success_light">

                    <TextView
                        android:id="@+id/txtPetAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 years"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/success"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/info">

                    <TextView
                        android:id="@+id/txtPetGender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Female"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/warning_light">

                    <TextView
                        android:id="@+id/txtPetSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Large"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/warning"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/txtPetDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Friendly and energetic dog who loves playing fetch and swimming..."
                android:textSize="13sp"
                android:textColor="@color/primary_text"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="12dp"/>

            <!-- Personality -->
            <TextView
                android:id="@+id/txtPersonality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Friendly, Energetic, Loyal"
                android:textSize="11sp"
                android:textColor="@color/success"
                android:background="@color/success_light"
                android:padding="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- Location & Contact -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/txtShelterInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Happy Paws Shelter • 123 Main St"
                    android:textSize="11sp"
                    android:textColor="@color/secondary_text"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/txtContactInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contact shelter for details"
                    android:textSize="10sp"
                    android:textColor="@color/hint_text"/>

            </LinearLayout>

            <!-- Health Status -->
            <TextView
                android:id="@+id/txtHealthStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Healthy • Vaccinated • Spayed/Neutered"
                android:textSize="11sp"
                android:textColor="@color/success"
                android:layout_marginBottom="6dp"/>

            <!-- Special Needs (Hidden by default) -->
            <TextView
                android:id="@+id/txtSpecialNeeds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Special Care Required"
                android:textSize="11sp"
                android:textColor="@color/warning"
                android:background="@color/warning_light"
                android:padding="6dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone"/>

            <!-- Bottom Action Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtAdoptionFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Free Adoption"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/success"/>

                    <TextView
                        android:id="@+id/txtDateAdded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Added: Mar 15, 2025"
                        android:textSize="9sp"
                        android:textColor="@color/hint_text"/>

                </LinearLayout>

                <!-- Admin Edit Button - Enhanced visibility -->
                <Button
                    android:id="@+id/btnAdminEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="👑 ADMIN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/admin_primary"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="16dp"
                    android:minWidth="90dp"
                    android:elevation="8dp"
                    android:stateListAnimator="@null"
                    android:visibility="visible"
                    android:alpha="1.0"
                    style="@style/Widget.AppCompat.Button.Colored"/>

                <Button
                    android:id="@+id/btnViewDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="Meet Me"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white"
                    android:paddingHorizontal="20dp"
                    android:minWidth="100dp"
                    style="@style/Widget.AppCompat.Button.Colored"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>