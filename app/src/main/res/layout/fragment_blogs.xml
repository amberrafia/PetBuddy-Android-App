<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EE"

    android:scrollbars="vertical"
    android:fadeScrollbars="false"
    android:scrollbarStyle="outsideOverlay"
    android:scrollbarThumbVertical="@drawable/custom_scrollbar"
    android:scrollbarTrackVertical="@android:color/transparent">



<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ================= CAT SECTION ================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🐱 Cat Grooming Videos"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#6A1B9A"
            android:layout_marginBottom="8dp"/>

        <!-- CAT VIDEO WITH THUMBNAIL -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="12dp">

            <!-- Thumbnail -->
            <ImageView
                android:id="@+id/imgCatThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/cat_thumbnail" />

            <ImageView
                android:id="@+id/imgCatPlay"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_play"
                app:tint="@android:color/white"/>



            <!-- Video -->
            <VideoView
                android:id="@+id/catVideo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>

        </FrameLayout>


        <!-- CAT IMAGE (CLICKABLE) -->
        <ImageView
            android:id="@+id/imgCatGrooming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/cat_grooming_tips"
            android:contentDescription="Cat grooming tips"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="32dp"/>

        <!-- ================= DOG SECTION ================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🐶 Dog Grooming Videos"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#6A1B9A"
            android:layout_marginBottom="8dp"/>

        <!-- DOG VIDEO WITH THUMBNAIL -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="12dp">

            <!-- Thumbnail -->
            <ImageView
                android:id="@+id/imgDogThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/dog_thumbnail" />

            <!-- Play Icon -->
            <ImageView
                android:id="@+id/imgDogPlay"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_play" />

            <!-- Video -->
            <VideoView
                android:id="@+id/dogVideo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>

        </FrameLayout>


        <!-- DOG IMAGE (CLICKABLE) -->
        <ImageView
            android:id="@+id/imgDogGrooming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/dog_grooming_tips"
            android:contentDescription="Dog grooming tips"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="32dp"/>

        <!-- ================= COLD & FEVER ================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤒 Cold and Fever Care"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#6A1B9A"
            android:layout_marginBottom="8dp"/>

        <!-- COLD & FEVER IMAGE (CLICKABLE) -->
        <ImageView
            android:id="@+id/imgColdFever"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/cold_fever_cats_dogs"
            android:contentDescription="Cold and fever care tips"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
