<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6C1CC"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔 Notifications"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2D5F5D"
            android:paddingBottom="20dp" />

        <!-- Feeding Reminder Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/feedCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FDECEF">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:text="🍽️ Feeding Reminder"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#2D5F5D"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"/>

                    <Switch
                        android:id="@+id/feedSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <TextView
                    android:id="@+id/feedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍽️ Feed Your Pet at 8:00 AM"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/editFeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Edit Time"
                    android:backgroundTint="#E8A7B4"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Playing Reminder Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/playCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FDECEF">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:text="🎾 Playing Reminder"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#2D5F5D"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"/>

                    <Switch
                        android:id="@+id/playSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <TextView
                    android:id="@+id/playText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎾 Play with Your Pet at 6:00 PM"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/editPlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Edit Time"
                    android:backgroundTint="#E8A7B4"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Test Notification Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FDECEF">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="🔔 Test Notifications"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#2D5F5D"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test your notification settings with sound and popup"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/testNotification"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔊 Test Popup"
                        android:backgroundTint="#E8A7B4"
                        android:textColor="#FFFFFF"
                        android:layout_marginRight="8dp"/>

                    <Button
                        android:id="@+id/testService"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚙️ Test Service"
                        android:backgroundTint="#A7B4E8"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Firebase Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#E8F5E8">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="🔥 Firebase Connected"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#2D5F5D"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your notification settings are now synced with Firebase! This means your reminders will be saved across devices and sessions."
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Debug Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FFF3E0">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="🔧 Notification Status"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#2D5F5D"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/debugStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Service: Not started\n• Last update: Never\n• Next feeding: Not scheduled\n• Next playing: Not scheduled"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:id="@+id/refreshStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 Refresh Status"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#E8F5E8">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="ℹ️ How it works"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#2D5F5D"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Set custom times for feeding and playing\n• Get popup reminders with sound\n• Snooze for 15 minutes if needed\n• Enable/disable reminders anytime\n• Data synced with Firebase cloud storage\n\n🔧 For background popups to work:\n• Allow 'Display over other apps' permission\n• Disable battery optimization for this app\n• Allow exact alarms in phone settings\n• Keep foreground service notification visible\n\n✅ Test notifications work immediately\n🚨 Scheduled notifications work even when app is closed"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
