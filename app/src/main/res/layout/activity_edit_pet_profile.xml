<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/soft_pink_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👑 Edit Pet Profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/soft_pink_dark"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Pet Photo Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📸 Pet Photo"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <ImageView
                    android:id="@+id/imgPetPhoto"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginBottom="12dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg"
                    android:src="@drawable/default_pet_image" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnChangePhoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📷 Change Photo"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/soft_pink_medium" />

                    <Button
                        android:id="@+id/btnRemovePhoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🗑️ Remove Photo"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/warning" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Basic Information Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🐾 Basic Information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/editPetName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Pet Name"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerSpecies"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editBreed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Breed"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerGender"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Age (in months)"
                    android:inputType="number"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerSize"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Color"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Description Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📝 Description"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/editDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Pet Description"
                    android:minLines="3"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editPersonality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Personality (e.g., friendly, playful)"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editSpecialTraits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Special Traits"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Health Information Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏥 Health Information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <Spinner
                    android:id="@+id/spinnerHealthStatus"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/checkVaccinated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vaccinated"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/checkNeutered"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Spayed/Neutered"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editMedicalCondition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Medical Condition (if any)"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editLastCheckup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Last Health Checkup Date"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editSpecialNeeds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Special Needs"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Location &amp; Shelter Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Location &amp; Shelter"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/editCity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="City"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editShelterName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Shelter Name"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editShelterLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Shelter Location"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editShelterContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Shelter Contact"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Adoption Requirements Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 Adoption Requirements"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/editMinAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Minimum Adopter Age"
                    android:inputType="number"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editHomeEnvironment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Home Environment Required"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editExperience"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Experience Required"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editAdditionalRequirements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Additional Requirements"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Contact Information Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📞 Contact Information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/editContactName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contact Person Name"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editContactPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contact Phone"
                    android:inputType="phone"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editContactEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contact Email"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Adoption Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💰 Adoption Details"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/soft_pink_dark"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/editAdoptionFee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Adoption Fee"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerAdoptionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancel"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/soft_pink_medium" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💾 Save Changes"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/soft_pink_dark" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>