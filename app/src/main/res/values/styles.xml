<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Stylish PetBuddy Title Style -->
    <style name="PetBuddyTitleStyle">
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:shadowColor">#80000000</item>
        <item name="android:shadowDx">3</item>
        <item name="android:shadowDy">3</item>
        <item name="android:shadowRadius">6</item>
        <item name="android:background">@drawable/text_gradient_background</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Stylish Subtitle Style -->
    <style name="PetBuddySubtitleStyle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">italic</item>
        <item name="android:textColor">#F5FFFFFF</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:shadowColor">#60000000</item>
        <item name="android:shadowDx">2</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">3</item>
    </style>

    <!-- Decorative emoji style -->
    <style name="EmojiStyle">
        <item name="android:textSize">22sp</item>
        <item name="android:shadowColor">#40000000</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>
</resources>